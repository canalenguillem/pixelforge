# ==============================================================================
# Photo Restore Pro - Environment Variables
# Copy this file to .env and fill in your own values:  cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Base de Datos (MariaDB)
# ------------------------------------------------------------------------------
DB_NAME=photo_restore
DB_USER=photo_restore_user
DB_PASSWORD=secure_password_123
DB_ROOT_PASSWORD=root_secure_123
DB_HOST=mariadb
DB_PORT=3306

# ------------------------------------------------------------------------------
# MongoDB (histórico de jobs/resultados)
# ------------------------------------------------------------------------------
MONGO_USER=photo_restore_user
MONGO_PASSWORD=mongo_secure_123
MONGO_DB=photo_restore_jobs
MONGO_HOST=mongodb
MONGO_PORT=27017

# ------------------------------------------------------------------------------
# Redis (cache, sesiones, rate limiting, broker de Celery)
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ------------------------------------------------------------------------------
# JWT
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=your_super_secret_key_change_in_production_32_chars_min
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# ------------------------------------------------------------------------------
# Backend
# ------------------------------------------------------------------------------
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
DEBUG=True
WORKERS=4

# ------------------------------------------------------------------------------
# ComfyUI (valor por defecto; el usuario puede sobrescribir por perfil)
# ------------------------------------------------------------------------------
COMFYUI_DEFAULT_URL=http://host.docker.internal:8188
COMFYUI_API_KEY=

# ------------------------------------------------------------------------------
# LLM APIs (el usuario puede agregar sus propias keys desde Settings)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk_test_xxx
ANTHROPIC_API_KEY=sk_test_xxx

# ------------------------------------------------------------------------------
# Storage
# ------------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
UPLOAD_FOLDER=/app/uploads
PROCESSED_FOLDER=/app/processed
ALLOWED_EXTENSIONS=jpg,jpeg,png,bmp,tiff

# ------------------------------------------------------------------------------
# Email (opcional)
# ------------------------------------------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ------------------------------------------------------------------------------
# Seguridad
# ------------------------------------------------------------------------------
ENCRYPTION_KEY=your_32_character_encryption_key_
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
